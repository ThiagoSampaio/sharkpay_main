{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anhskohbo/no-captcha": "^3.3",
        "developercielo/api-3.0-php": "^1.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "hisorange/browser-detect": "^4.3",
        "intervention/image": "^2.5",
        "laravel/framework": "^12.0",
        "laravel/helpers": "^1.4",
        "laravel/passport": "13.7.3",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^4.6",
        "league/omnipay": "^3.1",
        "maatwebsite/excel": "^3.1",
        "mews/purifier": "^3.3",
        "mpdf/mpdf": "^8.2",
        "omnipay/stripe": "^3.1",
        "php-curl-class/php-curl-class": "^9.1",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "sonata-project/google-authenticator": "^2.3",
        "stripe/stripe-php": "^7.70"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/developercielo/api-3.0-php",
            "options": {
                "symlink": false
            }
        }
    ],
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "app/Lib/Rave/",
            "app/Lib/Twocheckout/",
            "app/Lib/Twocheckout.php",
            "app/Console/Commands/*-bkp.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
