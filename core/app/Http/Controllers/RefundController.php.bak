<?php

namespace App\Http\Controllers;

use App\Models\Refund;
use App\Models\Invoice; // Assumindo que existe
use App\Services\RefundService;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\Validator;
use Carbon\Carbon;

class RefundController extends Controller
{
    protected $refundService;

    public function __construct(RefundService $refundService)
    {
        $this->middleware('auth:user');
        $this->refundService = $refundService;
    }

    public function index(Request $request)
    {
        $user = Auth::guard('user')->user();

        $query = Refund::forUser($user->id)
            ->with(['requestedBy', 'approvedBy']);

        // Filtros
        if ($request->status) {
            $query->where('status', $request->status);
        }

        if ($request->refund_type) {
            $query->where('refund_type', $request->refund_type);
        }

        if ($request->date_from) {
            $query->where('requested_at', '>=', $request->date_from);
        }

        if ($request->date_to) {
            $query->where('requested_at', '<=', $request->date_to);
        }

        if ($request->search) {
            $query->where(function($q) use ($request) {
                $q->where('refund_id', 'like', '%' . $request->search . '%')
                  ->orWhere('original_transaction_id', 'like', '%' . $request->search . '%');
            });
        }

        $refunds = $query->orderBy('created_at', 'desc')->paginate(15);

        $summary = [
            'total_requested' => Refund::forUser($user->id)->requested()->sum('refund_amount'),
            'total_approved' => Refund::forUser($user->id)->approved()->sum('refund_amount'),
            'total_completed' => Refund::forUser($user->id)->completed()->sum('refund_amount'),
            'total_rejected' => Refund::forUser($user->id)->rejected()->sum('refund_amount'),
        ];

        return view('user.refunds.index', compact('refunds', 'summary'));
    }

    public function show($id)
    {
        $user = Auth::guard('user')->user();
        $refund = Refund::forUser($user->id)->findOrFail($id);

        $transactionRefunds = Refund::getTransactionRefunds($refund->original_transaction_id);
        $totalRefunded = Refund::getTotalRefundedForTransaction($refund->original_transaction_id);

        return view('user.refunds.show', compact('refund', 'transactionRefunds', 'totalRefunded'));
    }

    public function create(Request $request)
    {
        $user = Auth::guard('user')->user();
        $transactionId = $request->transaction_id;

        // Buscar dados da transação
        $transaction = $this->getTransactionData($transactionId, $user->id);

        if (!$transaction) {
            return back()->with('error', 'Transação não encontrada.');
        }

        // Verificar se é elegível para reembolso
        $eligibility = $this->refundService->checkRefundEligibility($transactionId);

        if (!$eligibility['eligible']) {
            return back()->with('error', $eligibility['reason']);
        }

        $totalRefunded = Refund::getTotalRefundedForTransaction($transactionId);
        $availableForRefund = $transaction['amount'] - $totalRefunded;

        return view('user.refunds.create', compact('transaction', 'totalRefunded', 'availableForRefund'));
    }

    public function store(Request $request)
    {
        $user = Auth::guard('user')->user();

        $validator = Validator::make($request->all(), [
            'transaction_id' => 'required|string',
            'refund_type' => 'required|in:full,partial',
            'refund_amount' => 'required_if:refund_type,partial|numeric|min:0.01',
            'reason' => 'required|string|max:1000'
        ]);

        if ($validator->fails()) {
            return back()->withErrors($validator)->withInput();
        }

        try {
            // Buscar dados da transação
            $transaction = $this->getTransactionData($request->transaction_id, $user->id);

            if (!$transaction) {
                return back()->with('error', 'Transação não encontrada.');
            }

            // Verificar elegibilidade
            $eligibility = $this->refundService->checkRefundEligibility($request->transaction_id);

            if (!$eligibility['eligible']) {
                return back()->with('error', $eligibility['reason']);
            }

            // Calcular valor do reembolso
            if ($request->refund_type === 'full') {
                $refundAmount = $transaction['amount'];
            } else {
                $refundAmount = $request->refund_amount;

                // Verificar se o valor não excede o disponível
                $totalRefunded = Refund::getTotalRefundedForTransaction($request->transaction_id);
                $availableForRefund = $transaction['amount'] - $totalRefunded;

                if ($refundAmount > $availableForRefund) {
                    return back()->with('error', 'Valor excede o disponível para reembolso.');
                }
            }

            // Calcular taxa de reembolso (se aplicável)
            $feeAmount = $this->refundService->calculateRefundFee($refundAmount, $transaction['payment_method']);

            // Criar reembolso
            $refund = new Refund();
            $refund->original_transaction_id = $request->transaction_id;
            $refund->user_id = $user->id;
            $refund->requested_by = $user->id;
            $refund->original_amount = $transaction['amount'];
            $refund->refund_amount = $refundAmount;
            $refund->fee_amount = $feeAmount;
            $refund->refund_type = $request->refund_type;
            $refund->reason = $request->reason;
            $refund->status = 'requested';

            $refund->save();

            // Notificar administradores (implementar)
            // $this->refundService->notifyRefundRequest($refund);

            return redirect()->route('user.refunds.show', $refund->id)
                ->with('success', 'Solicitação de reembolso criada com sucesso!');

        } catch (\Exception $e) {
            return back()->with('error', 'Erro ao criar reembolso: ' . $e->getMessage());
        }
    }

    public function cancel($id)
    {
        $user = Auth::guard('user')->user();
        $refund = Refund::forUser($user->id)->findOrFail($id);

        if ($refund->status !== 'requested') {
            return back()->with('error', 'Este reembolso não pode ser cancelado.');
        }

        try {
            $refund->update(['status' => 'cancelled']);

            return back()->with('success', 'Reembolso cancelado com sucesso!');

        } catch (\Exception $e) {
            return back()->with('error', 'Erro ao cancelar reembolso: ' . $e->getMessage());
        }
    }

    public function checkEligibility(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'transaction_id' => 'required|string'
        ]);

        if ($validator->fails()) {
            return response()->json(['error' => $validator->errors()], 400);
        }

        $eligibility = $this->refundService->checkRefundEligibility($request->transaction_id);
        $totalRefunded = Refund::getTotalRefundedForTransaction($request->transaction_id);

        // Buscar dados da transação
        $user = Auth::guard('user')->user();
        $transaction = $this->getTransactionData($request->transaction_id, $user->id);

        $availableForRefund = $transaction ? $transaction['amount'] - $totalRefunded : 0;

        return response()->json([
            'eligible' => $eligibility['eligible'],
            'reason' => $eligibility['reason'] ?? null,
            'total_refunded' => $totalRefunded,
            'available_for_refund' => $availableForRefund,
            'formatted_available' => 'R$ ' . number_format($availableForRefund, 2, ',', '.')
        ]);
    }

    public function calculateFee(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'amount' => 'required|numeric|min:0.01',
            'payment_method' => 'required|string'
        ]);

        if ($validator->fails()) {
            return response()->json(['error' => $validator->errors()], 400);
        }

        $feeAmount = $this->refundService->calculateRefundFee($request->amount, $request->payment_method);
        $netAmount = $request->amount - $feeAmount;

        return response()->json([
            'refund_amount' => $request->amount,
            'fee_amount' => $feeAmount,
            'net_amount' => $netAmount,
            'formatted_fee' => 'R$ ' . number_format($feeAmount, 2, ',', '.'),
            'formatted_net' => 'R$ ' . number_format($netAmount, 2, ',', '.')
        ]);
    }

    public function history(Request $request)
    {
        $user = Auth::guard('user')->user();

        $startDate = $request->start_date ? Carbon::parse($request->start_date) : Carbon::now()->subMonths(6);
        $endDate = $request->end_date ? Carbon::parse($request->end_date) : Carbon::now();

        $refunds = Refund::forUser($user->id)
            ->whereBetween('requested_at', [$startDate, $endDate])
            ->with(['requestedBy', 'approvedBy'])
            ->orderBy('requested_at', 'desc')
            ->get();

        $summary = [
            'total_amount' => $refunds->sum('refund_amount'),
            'total_fees' => $refunds->sum('fee_amount'),
            'total_net' => $refunds->sum(function($refund) {
                return $refund->getNetRefundAmount();
            }),
            'completed_count' => $refunds->where('status', 'completed')->count(),
            'rejected_count' => $refunds->where('status', 'rejected')->count(),
            'average_processing_time' => $refunds->where('status', 'completed')->avg('days_processing')
        ];

        return view('user.refunds.history', compact('refunds', 'summary', 'startDate', 'endDate'));
    }

    public function export(Request $request)
    {
        $user = Auth::guard('user')->user();

        $startDate = $request->start_date ? Carbon::parse($request->start_date) : Carbon::now()->subMonths(6);
        $endDate = $request->end_date ? Carbon::parse($request->end_date) : Carbon::now();

        $refunds = Refund::forUser($user->id)
            ->whereBetween('requested_at', [$startDate, $endDate])
            ->orderBy('requested_at', 'desc')
            ->get();

        // Implementar exportação (CSV, PDF, etc.)
        return response()->json(['message' => 'Export functionality to be implemented']);
    }

    // Método auxiliar para buscar dados da transação
    private function getTransactionData($transactionId, $userId)
    {
        // Buscar na tabela de invoices ou outras tabelas de transação
        $invoice = Invoice::where('ref', $transactionId)
                         ->where('user_id', $userId)
                         ->first();

        if ($invoice) {
            return [
                'id' => $invoice->id,
                'amount' => $invoice->amount,
                'payment_method' => $invoice->payment_method ?? 'unknown',
                'status' => $invoice->status,
                'created_at' => $invoice->created_at
            ];
        }

        // Buscar em outras tabelas de transação se necessário
        return null;
    }
}